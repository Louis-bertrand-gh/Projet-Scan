# ═══════════════════════════════════════════════════════════════════════
# .env.local — Variables d'environnement locales (ne pas committer)
#
# Copiez ce fichier en .env.local et renseignez vos clés Supabase.
# Trouvez ces valeurs dans : Supabase Dashboard > Settings > API
# ═══════════════════════════════════════════════════════════════════════

# URL de votre projet Supabase (ex: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://njfenretdqzamxviahwo.supabase.co
# Clé publique client (safe côté client)
# Le projet accepte l'un de ces deux noms selon votre dashboard Supabase.
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_ANON_KEY
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=VOTRE_PUBLISHABLE_KEY
